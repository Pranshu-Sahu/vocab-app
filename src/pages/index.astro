---
/**
 * index.astro — Home page.
 *
 * Thin orchestrator: injects word data into window.__vocabWords
 * and loads the modular learning engine from public/scripts/.
 */
import type { Word } from '../types/word';
import BaseLayout from '../layouts/BaseLayout.astro';
import words from '../data/words.json';
import passages from '../data/passages.json';
import '../styles/global.css';

const typedWords = words as Word[];
---

<BaseLayout title="VocabBuilder — Master Your Words">
  <!-- App root — all screens are rendered here by ui.js -->
  <div class="app-container">
    <div id="app-root"></div>
  </div>

  <!-- Bridge: expose server-side data to the static client script -->
  <script is:inline define:vars={{ typedWords, passages }}>
    window.__vocabWords = typedWords;
    window.__vocabPassages = passages;
  </script>

  <!-- Load the modular learning engine as an ES module -->
  <script is:inline type="module" src="/scripts/app.js"></script>
</BaseLayout>
