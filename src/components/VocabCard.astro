---
// VocabCard.astro — The main flashcard UI, composing sub-components
import CardHeader from './CardHeader.astro';
import SectionLabel from './SectionLabel.astro';
import ChipList from './ChipList.astro';

// SVG icon paths
const ICON_MEANING   = 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z';
const ICON_SYNONYMS  = 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2';
const ICON_ANTONYMS  = 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z';
---

<main class="vocab-card" id="vocab-card" aria-live="polite">
  <CardHeader />

  <!-- Word Title -->
  <div class="word-container">
    <h2 class="word-title" id="word-title">Word</h2>
  </div>

  <!-- Meaning -->
  <div class="content-section">
    <SectionLabel label="Simple Explanation" iconPath={ICON_MEANING} />
    <p class="explanation-text" id="explanation-text">Simple explanation of the word goes here.</p>
  </div>

  <!-- Synonyms -->
  <ChipList id="synonyms-list" label="Synonyms" iconPath={ICON_SYNONYMS} />

  <!-- Antonyms -->
  <ChipList id="antonyms-list" label="Antonyms" iconPath={ICON_ANTONYMS} />

  <!-- Navigation Controls -->
  <div class="nav-controls">
    <button id="btn-prev" class="nav-btn" aria-label="Previous word" disabled>
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      Prev
    </button>
    <button id="btn-next" class="nav-btn" aria-label="Next word">
      Next
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </button>
  </div>
</main>
